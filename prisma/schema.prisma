generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  SELLER
  ADMIN
}

enum Status {
  ACTIVE
  SUSPENDED
}

enum PriceBadge {
  NEGOTIABLE
  NON_NEGOTIABLE
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String? // Nullable for users who sign up via Google
  googleId     String?  @unique
  role         Role     @default(USER)
  status       Status   @default(ACTIVE)
  avatar       String?
  phoneNumber  String?
  location     String?
  bio          String?  @db.Text
  techPresence String? // Links to GitHub, LinkedIn, or personal site
  isVerified   Boolean  @default(false)
  joinDate     DateTime @default(now())

  reviews       Review[]
  sellerProfile Seller?  @relation("UserToSeller")
}

model Gadget {
  id          String @id @default(uuid())
  slug        String? @unique
  name        String
  brand       String
  price       Float  @default(0)
  categoryId  String
  image       String
  description String
  specs       Json // Store key-value specs flexibly

  // Relations
  category Category        @relation(fields: [categoryId], references: [id])
  prices   NigerianPrices?
  reviews  Review[]
}

model NigerianPrices {
  id       String @id @default(uuid())
  gadgetId String @unique
  jumia    Float?
  konga    Float?
  slot     Float?
  average  Float?

  gadget Gadget @relation(fields: [gadgetId], references: [id], onDelete: Cascade)
}

model Category {
  id       String   @id @default(uuid())
  name     String   @unique
  image    String
  badges   String[]
  discount Int?

  gadgets Gadget[]
}

model Review {
  id                 String   @id @default(uuid())
  gadgetId           String
  userId             String
  rating             Int // 1 to 5
  title              String?
  comment            String
  pros               String[]
  cons               String[]
  isVerifiedPurchase Boolean  @default(false)
  helpfulCount       Int      @default(0)
  image              String?
  isFlagged          Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @default(now()) @updatedAt

  gadget Gadget @relation(fields: [gadgetId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Seller {
  id          String   @id @default(uuid())
  userId      String   @unique
  name        String
  logo        String
  about       String?  @db.Text
  phoneNumber String?
  location    String
  city        String
  rating      Float    @default(0)
  reviewCount Int      @default(0)
  isVerified  Boolean  @default(false)
  specialty   String
  memberSince DateTime @default(now())

  user    User           @relation("UserToSeller", fields: [userId], references: [id], onDelete: Cascade)
  gadgets SellerGadget[]
}

model SellerGadget {
  id          String     @id @default(uuid())
  sellerId    String
  description String     @db.Text
  specs       Json       @default("{}")
  images      String[]
  views       Int        @default(0)
  price       Float
  priceBadge  PriceBadge @default(NON_NEGOTIABLE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @default(now()) @updatedAt

  seller Seller @relation(fields: [sellerId], references: [id])
}

model BlogPost {
  id           String   @id @default(uuid())
  title        String
  excerpt      String
  content      String   @db.Text
  image        String
  commentCount Int      @default(0)
  createdAt    DateTime @default(now())
}

model AdminNotification {
  id        String   @id @default(uuid())
  title     String
  message   String
  type      String // info, success, warning, error
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}
